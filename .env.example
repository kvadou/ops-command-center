# Ops Command Center — Environment Variables
# Copy to .env and fill in your values

# === Database ===
DATABASE_URL=postgresql://localhost:5432/acme_ops
NODE_ENV=development
LOG_LEVEL=info

# === Auth ===
JWT_SECRET=your-jwt-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === External Services (all optional — app runs with stubs if not set) ===

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...

# AI Features
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Email (Brevo)
BREVO_API_KEY=xkeysib-...

# Maps
REACT_APP_GOOGLE_MAPS_API_KEY=AIza...

# Sentry (error monitoring)
SENTRY_DSN_BACKEND=https://...@sentry.io/...
VITE_SENTRY_DSN=https://...@sentry.io/...

# Image hosting (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=your-key
CLOUDINARY_API_SECRET=your-secret
