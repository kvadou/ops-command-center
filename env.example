# Ops Command Center - Environment Variables
# Copy this file to .env and fill in your actual values.
# Only DATABASE_URL and JWT_SECRET are required to boot.
# All external service keys are optional — the app stubs them with mock data.

# =============================================================================
# REQUIRED
# =============================================================================
DATABASE_URL=postgres://user:password@localhost:5432/ops_command_center
JWT_SECRET=your_jwt_secret_here

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# =============================================================================
# OPTIONAL — External Integrations (app runs with stubs if not set)
# =============================================================================

# TutorCruncher (workforce management API)
# TUTORCRUNCHER_API_TOKEN=your_token
# TUTORCRUNCHER_API_BASE=https://secure.tutorcruncher.com/api/

# Stripe (payment processing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Cloudinary (image hosting)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Brevo (transactional email)
# BREVO_API_KEY=your_brevo_key

# Klaviyo (email marketing)
# KLAVIYO_API_KEY=your_klaviyo_key

# Meta Ads (Facebook/Instagram)
# META_APP_ID=your_app_id
# META_APP_SECRET=your_app_secret
# META_ACCESS_TOKEN=your_access_token
# META_AD_ACCOUNT_ID=act_123456789

# Google Ads
# GOOGLE_ADS_CLIENT_ID=your_client_id
# GOOGLE_ADS_CLIENT_SECRET=your_client_secret
# GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
# GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
# GOOGLE_ADS_CUSTOMER_ID=1234567890

# Missive (team inbox / communications)
# MISSIVE_API_KEY=your_missive_key

# Webflow (CMS sync)
# WEBFLOW_API_TOKEN=your_webflow_token
# WEBFLOW_TUTORS_COLLECTION_ID=your_collection_id
# WEBFLOW_SITE_ID=your_site_id

# Google Maps (geocoding)
# GOOGLE_MAPS_API_KEY=your_key
# VITE_GOOGLE_MAPS_API_KEY=your_key
